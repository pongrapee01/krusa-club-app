VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Set API base URL that already includes /api prefix.
# Example local dev: https://localhost:44392/api
# Example production: https://api.example.com/api
VITE_API_BASE_URL=https://localhost:44392/api

# ตั้งเป็น true เพื่อดู UI เช็คชื่อ (การ์ดรายชื่อ) โดยไม่ต้องมี backend — ข้อมูลจาก src/mocks/attendanceRollCallMock.ts
#VITE_USE_ATTENDANCE_MOCK=true
